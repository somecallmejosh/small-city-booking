<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Small City Studio" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Small City">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>
    <meta name="vapid-public-key" content="<%= Rails.application.config.vapid_public_key %>">

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-stone-50 font-sans antialiased">
    <% nav_item = ->(active) { active ? "block px-3 py-2 rounded-lg font-medium bg-red-50 text-red-700" : "block px-3 py-2 rounded-lg text-stone-600 hover:bg-stone-50 hover:text-stone-900" } %>
    <%= render(HeaderComponent.new) do |c| %>
      <% c.with_desktop_nav do %>
        <% if authenticated? %>
          <%= link_to "My Bookings", bookings_path, class: nav_item.(current_page?(bookings_path)) %>
          <%= link_to "Available Sessions", root_path, class: nav_item.(current_page?(root_path)) %>
          <%= link_to "My Profile", edit_profile_path, class: nav_item.(current_page?(edit_profile_path)) %>
          <%= link_to "Help", help_path, class: nav_item.(current_page?(help_path)) %>

          <div data-controller="push-subscription"
               data-push-subscription-vapid-public-key-value="<%= Rails.application.config.vapid_public_key %>" class="ml-6">
            <button data-push-subscription-target="button"
                    data-action="push-subscription#toggle"
                    class="<%= btn_secondary %>">
              Notifications
            </button>
          </div>
          <div class="flex items-center ml-4">
            <%= button_to "Sign Out", session_path, method: :delete,
                  class: btn_primary %>
          </div>
        <% else %>
          <div class="flex items-center gap-1.5 ml-4">
            <%= link_to "Sign Up", new_registration_path, class: btn_secondary %>
            <%= link_to "Sign In", new_session_path, class: btn_primary %>
          </div>
        <% end %>
      <% end %>
      <% c.with_mobile_nav do %>
        <div class="flex flex-col gap-2 p-4">
          <% if authenticated? %>
            <%= link_to "My Bookings", bookings_path, class: nav_item.(current_page?(bookings_path)) %>
            <%= link_to "Available Sessions", root_path, class: nav_item.(current_page?(root_path)) %>
            <%= link_to "My Profile", edit_profile_path, class: nav_item.(current_page?(edit_profile_path)) %>
            <%= link_to "Help", help_path, class: nav_item.(current_page?(help_path)) %>
            <div data-controller="push-subscription"
                 data-push-subscription-vapid-public-key-value="<%= Rails.application.config.vapid_public_key %>">
              <button data-push-subscription-target="button"
                      data-action="push-subscription#toggle"
                      class="<%= btn_secondary %>">
                Notifications
              </button>
            </div>
            <%= button_to "Sign Out", session_path, method: :delete,
                  class: btn_primary %>
          <% else %>
            <%= link_to "Sign Up", new_registration_path, class: btn_primary %>
            <%= link_to "Sign In", new_session_path, class: btn_primary %>
          <% end %>
        </div>
      <% end %>
    <% end %>

    <% flash.each do |type, message| %>
      <div class="mx-auto max-w-6xl px-4 pt-4 lg:px-8">
        <%= render FlashMessageComponent.new(type: type.to_sym, message: message) %>
      </div>
    <% end %>

    <% if authenticated? && !Current.user.email_verified? %>
      <div class="mx-auto max-w-6xl px-4 pt-2 lg:px-8">
        <div class="flex flex-col items-center justify-between gap-1 lg:flex-col lg:gap-3 rounded-lg border border-yellow-200 bg-yellow-50 px-4 py-3 text-yellow-800">
          <span>Please verify your email address to enable booking.</span>
          <%= link_to "Resend verification email", new_email_verification_path,
                class: "whitespace-nowrap font-medium underline hover:no-underline" %>
        </div>
      </div>
    <% end %>

    <main class="mx-auto max-w-6xl px-4 py-8 lg:px-8">
      <%= yield %>
    </main>
  </body>
</html>
