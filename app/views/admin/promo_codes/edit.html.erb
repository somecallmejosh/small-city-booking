<% content_for :title, "Edit #{@promo_code.name} — Admin" %>

<div class="mb-6">
  <%= render BreadcrumbComponent.new(items: [
    { label: "Admin",       path: admin_root_path },
    { label: "Promo Codes", path: admin_promo_codes_path },
    { label: @promo_code.name, path: admin_promo_code_path(@promo_code) },
    { label: "Edit",        path: nil }
  ]) %>
  <h1 class="mt-1 text-2xl font-semibold text-stone-900">Edit Promo Code</h1>
</div>

<div class="<%= card %> max-w-lg">
  <%= form_with model: [ :admin, @promo_code ] do |f| %>
    <%= render "form", f: f, promo_code: @promo_code %>
  <% end %>
</div>
