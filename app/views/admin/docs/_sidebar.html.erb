<nav aria-label="Admin docs topics">
  <p class="mb-3 text-xs font-semibold uppercase tracking-wide text-stone-400">Admin Manual</p>
  <ul class="space-y-1 text-sm">
    <% [
      ["Overview",          admin_docs_path],
      ["Slots",             admin_docs_slots_path],
      ["Bookings",          admin_docs_bookings_path],
      ["Customers",         admin_docs_customers_path],
      ["Waitlist",          admin_docs_waitlist_path],
      ["Agreement",         admin_docs_agreement_path],
      ["Settings",          admin_docs_settings_path],
      ["Tips & Practices",  admin_docs_tips_path]
    ].each do |label, path| %>
      <li>
        <%= link_to label, path,
              class: "block rounded-md px-3 py-1.5 #{current_page?(path) ?
                'bg-stone-100 font-medium text-stone-900' :
                'text-stone-600 hover:bg-stone-50 hover:text-stone-900'}" %>
      </li>
    <% end %>
  </ul>

  <div class="mt-6 border-t border-stone-200 pt-4">
    <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-stone-400">Customer Docs</p>
    <%= link_to "View customer help →", help_path,
          class: "block text-sm text-stone-500 hover:text-stone-900" %>
  </div>
</nav>
