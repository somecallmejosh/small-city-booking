<% content_for :title, "Admin Manual — Small City Studio" %>

<div class="flex gap-8 lg:gap-12">
  <aside class="hidden lg:block w-52 flex-shrink-0">
    <%= render "sidebar" %>
  </aside>

  <div class="min-w-0 flex-1">
    <div class="mb-8">
      <h1 class="text-2xl font-semibold text-stone-900">Admin Manual</h1>
      <p class="mt-2 text-stone-500">A complete reference for managing Small City Studio.</p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      <% [
        { label: "Slots",       path: admin_docs_slots_path,     desc: "Create single or bulk slots; handle overnight sessions." },
        { label: "Bookings",    path: admin_docs_bookings_path,  desc: "Filter, view, create manual bookings, and cancel." },
        { label: "Customers",   path: admin_docs_customers_path, desc: "Search, view, create, and edit customer accounts." },
        { label: "Agreement",   path: admin_docs_agreement_path, desc: "Publish new versions and view agreement history." },
        { label: "Settings",    path: admin_docs_settings_path,  desc: "Update studio name, rate, and cancellation window." },
        { label: "Tips",        path: admin_docs_tips_path,      desc: "Best practices for running your studio smoothly." }
      ].each do |topic| %>
        <%= link_to topic[:path], class: "block rounded-xl border border-stone-200 bg-white p-5 shadow-sm hover:border-stone-300 hover:shadow-md transition-shadow" do %>
          <p class="font-medium text-stone-900"><%= topic[:label] %></p>
          <p class="mt-1 text-sm text-stone-500"><%= topic[:desc] %></p>
        <% end %>
      <% end %>
    </div>

    <div class="mt-8 rounded-xl border border-dashed border-stone-300 bg-stone-50 p-5">
      <p class="text-sm font-medium text-stone-700">Customer-Facing Documentation</p>
      <p class="mt-1 text-sm text-stone-500">
        See what your customers see when they visit the Help section.
      </p>
      <%= link_to "View customer help →", help_path,
            class: "mt-3 inline-block text-sm font-medium text-stone-700 underline hover:text-stone-900" %>
    </div>
  </div>
</div>
