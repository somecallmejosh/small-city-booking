<% content_for :title, @settings&.studio_name || "Small City Studio" %>

<div data-controller="slot-selection"
     data-slot-selection-rate-cents-value="<%= @settings&.hourly_rate_cents || 0 %>">

  <div class="mb-8">
    <h1 class="text-3xl font-bold text-stone-900"><%= @settings&.studio_name || "Small City Studio" %></h1>
    <% if @settings&.studio_description.present? %>
      <p class="mt-2 text-stone-600 text-balance"><%= @settings.studio_description %></p>
    <% end %>
    <p class="mt-1 text-stone-500">
      $<%= number_with_precision(@settings&.hourly_rate_cents.to_f / 100, precision: 2) %> / hour
    </p>
  </div>

  <%= turbo_stream_from "slots" %>

  <% if @slots_by_date.any? %>

    <div class="mt-6 rounded-xl border border-stone-200 bg-white p-5 shadow-sm sticky top-18 mb-6 z-10">
      <p class="text-stone-600" data-slot-selection-target="summary">
        Select slots to book
      </p>

      <% if authenticated? %>
        <%= form_with url: slot_holds_path, method: :post, data: { turbo: false } do |f| %>
          <div class="mt-4">
            <button type="button"
                    data-slot-selection-target="checkoutButton"
                    data-action="click->slot-selection#submit"
                    class="<%= btn_primary %>"
                    disabled>
              Continue to Checkout
            </button>
          </div>
        <% end %>
      <% else %>
        <div class="mt-4">
          <%= link_to "Sign in to book", new_session_path, class: btn_primary %>
        </div>
      <% end %>
    </div>

    <div class="space-y-6">
      <% @slots_by_date.each do |date, slots| %>
        <div class="rounded-xl border border-stone-200 bg-white p-5 shadow-sm">
          <h2 class="mb-3 font-semibold text-stone-700">
            <%= date.strftime("%A, %B %-d") %>
          </h2>
          <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-8 gap-2">
            <% slots.each do |slot| %>
              <%= render "slots/slot", slot: slot %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>


  <% else %>
    <div class="<%= card %>">
      <p class="text-center text-stone-500">No upcoming slots available. Check back soon.</p>

      <% unless Current.user.admin? %>
        <div class="mt-4 border-t border-stone-100 pt-4 text-center">
          <% if @on_waitlist %>
            <p class="text-stone-600 mb-3">
              You're on the waitlist. We'll email <strong><%= Current.user.email_address %></strong> when slots open up.
            </p>
            <%= button_to "Leave waitlist", waitlist_entry_path(@waitlist_entry), method: :delete,
                  class: btn_secondary %>
          <% else %>
            <p class="text-stone-600 mb-3">Join the waitlist and we'll email you when slots become available.</p>
            <%= button_to "Join waitlist", waitlist_entries_path, method: :post,
                  class: btn_primary %>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
