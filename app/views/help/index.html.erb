<% content_for :title, "Help — Small City Studio" %>

<div class="flex gap-8 lg:gap-12">
  <aside class="hidden lg:block w-52 flex-shrink-0">
    <%= render "sidebar" %>
  </aside>

  <div class="min-w-0 flex-1">
    <div class="mb-8">
      <h1 class="text-2xl font-semibold text-stone-900">Help Center</h1>
      <p class="mt-2 text-stone-500">Everything you need to know about booking studio time at Small City.</p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      <% [
        { label: "Getting Started",    path: help_getting_started_path,  desc: "Create an account and book your first session." },
        { label: "Booking Calendar",   path: help_calendar_path,         desc: "Understand slot colors and how to select hours." },
        { label: "Checkout & Payment", path: help_checkout_path,         desc: "How holds, the countdown timer, and Stripe work." },
        { label: "Cancellations",      path: help_cancellations_path,    desc: "Cancel a booking and understand the refund policy." },
        { label: "Notifications",      path: help_notifications_path,    desc: "Enable push notifications for booking updates." },
        { label: "Account & Sign In",  path: help_account_path,          desc: "Manage your account and reset your password." },
        { label: "Terms of Booking",   path: help_terms_path,            desc: "What you agree to when completing a booking." }
      ].each do |topic| %>
        <%= link_to topic[:path], class: "block rounded-xl border border-stone-200 bg-white p-5 shadow-sm hover:border-stone-300 hover:shadow-md transition-shadow" do %>
          <p class="font-medium text-stone-900"><%= topic[:label] %></p>
          <p class="mt-1 text-sm text-stone-500"><%= topic[:desc] %></p>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
