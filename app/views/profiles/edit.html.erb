<% content_for :title, "My Profile — Small City Studio" %>

<div class="<%= session_form_wrapper %>">
  <h1 class="text-xl font-semibold text-stone-900">My Profile</h1>

  <% if @user.errors.any? %>
    <div class="rounded-lg border border-red-200 bg-red-50 p-3 text-red-700 space-y-1">
      <% @user.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <%= form_with model: @user, url: profile_path, method: :patch, multipart: true do |f| %>
    <div>
      <p class="<%= form_label %>">Profile Photo</p>
      <% if @user.avatar.attached? %>
        <div class="mb-3">
          <%= avatar_tag(@user, size: 80, css_class: "rounded-full") %>
        </div>
      <% end %>
      <p class="mb-1.5 text-xs text-stone-500">
        JPEG, PNG, or WebP · max 5 MB · center your face for best results
      </p>
      <%= f.file_field :avatar,
            accept: "image/jpeg,image/png,image/webp",
            class: "block w-full text-stone-600
                    file:mr-4 file:py-2 file:px-4 file:rounded-lg
                    file:border-0 file:file:font-medium
                    file:bg-stone-100 file:text-stone-700
                    hover:file:bg-stone-200 cursor-pointer" %>
    </div>
    <br />
    <div>
      <%= f.label :name, "Name", class: form_label %>
      <%= f.text_field :name, class: input_field,
            autocomplete: "name",
            placeholder: "Your name" %>
    </div>
    <br />
    <div>
      <%= f.label :phone, "Phone (optional)", class: form_label %>
      <%= f.telephone_field :phone, class: input_field,
            autocomplete: "tel",
            placeholder: "+1 (555) 000-0000" %>
    </div>
    <br />
    <%= f.submit "Save Changes", class: "#{btn_primary}" %>
  <% end %>
</div>
