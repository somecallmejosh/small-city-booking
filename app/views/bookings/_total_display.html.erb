<div class="mt-4 border-t border-stone-100 pt-4 space-y-1">
  <% if booking.discounted? %>
    <p class="text-stone-600">
      Subtotal: <span class="font-medium">$<%= number_with_precision(booking.total_cents / 100.0, precision: 2) %></span>
    </p>
    <p class="text-green-700">
      Discount (<%= booking.promo_code.discount_percent %>% off):
      <span class="font-medium">-$<%= number_with_precision(booking.discount_cents / 100.0, precision: 2) %></span>
    </p>
    <p class="font-semibold text-stone-900 border-t border-stone-100 pt-1 mt-1">
      Total: $<%= number_with_precision(booking.charged_cents / 100.0, precision: 2) %>
    </p>
  <% else %>
    <p class="font-semibold text-stone-900">
      Total: $<%= number_with_precision(booking.total_cents / 100.0, precision: 2) %>
    </p>
  <% end %>
</div>
